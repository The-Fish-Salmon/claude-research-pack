# Build artifacts
dist-desktop/
*.zip

# Bundled-at-package-time helper copies (regenerated by prepare-desktop-pack.ps1)
desktop-skills/*/bin/

# Node
node_modules/
package-lock.json
npm-debug.log*

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
*.egg-info/

# Settings backups (created by both installers)
*.bak.*

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*~

# Stray Obsidian metadata if the pack root is ever opened as a vault
.obsidian/

# Local secrets — should never appear, but defense-in-depth
.env
.env.*
*.key
*credentials*
secrets.*
