{
  "mcpServers": {
    "university-paper-access": {
      "type": "stdio",
      "command": "uv",
      "args": [
        "run",
        "--no-project",
        "--with",
        "mcp>=1.0.0",
        "--with",
        "httpx>=0.27.0",
        "--directory",
        "${HOME}/.claude/mcp-servers/university-paper-access",
        "python",
        "server.py"
      ],
      "env": {
        "PAPER_DOWNLOAD_DIR": "${PAPER_DOWNLOAD_DIR}",
        "UNPAYWALL_EMAIL": "${UNPAYWALL_EMAIL}"
      }
    },
    "arxiv": {
      "type": "stdio",
      "command": "arxiv-mcp-server",
      "args": [],
      "env": {
        "ARXIV_STORAGE_PATH": "${ARXIV_STORAGE_PATH}"
      }
    },
    "semantic-scholar": {
      "type": "stdio",
      "command": "semanticscholar-mcp-server",
      "args": []
    },
    "paper-search": {
      "type": "stdio",
      "command": "uv",
      "args": [
        "run",
        "--with",
        "paper-search-mcp",
        "python",
        "-c",
        "from paper_search_mcp.server import mcp; mcp.run(transport=\"stdio\")"
      ]
    },
    "paper-mcp": {
      "type": "stdio",
      "command": "paper-mcp",
      "args": []
    },
    "scihub": {
      "type": "stdio",
      "command": "uv",
      "args": [
        "run",
        "--no-project",
        "--with",
        "mcp>=1.0.0",
        "--with",
        "requests",
        "--with",
        "beautifulsoup4",
        "--with",
        "scihub",
        "--directory",
        "${HOME}/.claude/mcp-servers/Sci-Hub-MCP-Server",
        "python",
        "sci_hub_server.py"
      ]
    },
    "obsidian": {
      "type": "stdio",
      "command": "node",
      "args": [
        "${HOME}/.claude/mcp-servers/obsidian-wrapper.js",
        "${OBSIDIAN_VAULT_PATH}"
      ],
      "env": {
        "OBSIDIAN_API_KEY": "${OBSIDIAN_API_KEY}"
      }
    }
  }
}
