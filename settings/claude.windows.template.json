{
  "mcpServers": {
    "university-paper-access": {
      "type": "stdio",
      "command": "uv",
      "args": [
        "run",
        "--no-project",
        "--with",
        "mcp>=1.0.0",
        "--with",
        "httpx>=0.27.0",
        "--directory",
        "%USERPROFILE%/.claude/mcp-servers/university-paper-access",
        "python",
        "server.py"
      ]
    },
    "arxiv": {
      "type": "stdio",
      "command": "uv",
      "args": [
        "run",
        "--with",
        "arxiv-mcp-server",
        "arxiv-mcp-server"
      ]
    },
    "semantic-scholar": {
      "type": "stdio",
      "command": "uv",
      "args": [
        "run",
        "--with",
        "semanticscholar-mcp-server",
        "semanticscholar-mcp-server"
      ]
    },
    "paper-search": {
      "type": "stdio",
      "command": "uv",
      "args": [
        "run",
        "--with",
        "paper-search-mcp",
        "python",
        "-c",
        "from paper_search_mcp.server import mcp; mcp.run(transport=\"stdio\")"
      ]
    },
    "paper-mcp": {
      "type": "stdio",
      "command": "uv",
      "args": [
        "run",
        "--with",
        "paper-mcp",
        "paper-mcp"
      ]
    },
    "scihub": {
      "type": "stdio",
      "command": "uv",
      "args": [
        "run",
        "--no-project",
        "--with",
        "mcp>=1.0.0",
        "--with",
        "requests",
        "--with",
        "beautifulsoup4",
        "--with",
        "scihub",
        "--directory",
        "%USERPROFILE%/.claude/mcp-servers/Sci-Hub-MCP-Server",
        "python",
        "sci_hub_server.py"
      ]
    },
    "obsidian": {
      "type": "stdio",
      "command": "node",
      "args": [
        "%USERPROFILE%/.claude/mcp-servers/obsidian-wrapper.js"
      ]
    }
  },
  "_comment_env": "Runtime env vars (PAPER_DOWNLOAD_DIR, UNPAYWALL_EMAIL, ARXIV_STORAGE_PATH, OBSIDIAN_VAULT_PATH, OBSIDIAN_API_KEY) are inherited from the parent process -- set them with `setx FOO BAR` and re-open your shell BEFORE launching Claude Code. We don't put them in `env: {}` here because Claude does not expand %FOO% placeholders when it spawns MCP servers; static values would freeze the config. The %USERPROFILE% paths above ARE expanded at install time by install-mcp-servers.ps1.",
  "_comment_obsidian": "The obsidian server reads OBSIDIAN_API_KEY and OBSIDIAN_VAULT_PATH from the inherited environment via mcp-obsidian. Make sure those are set with setx before first launch."
}
