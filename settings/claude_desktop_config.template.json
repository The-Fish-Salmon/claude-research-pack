{
  "mcpServers": {
    "arxiv": {
      "command": "uv",
      "args": [
        "run",
        "--with",
        "arxiv-mcp-server",
        "arxiv-mcp-server"
      ]
    },
    "semantic-scholar": {
      "command": "uv",
      "args": [
        "run",
        "--with",
        "semanticscholar-mcp-server",
        "semanticscholar-mcp-server"
      ]
    },
    "paper-search": {
      "command": "uv",
      "args": [
        "run",
        "--with",
        "paper-search-mcp",
        "python",
        "-c",
        "from paper_search_mcp.server import mcp; mcp.run(transport=\"stdio\")"
      ]
    },
    "paper-mcp": {
      "command": "uv",
      "args": [
        "run",
        "--with",
        "paper-mcp",
        "paper-mcp"
      ]
    },
    "obsidian": {
      "command": "node",
      "args": [
        "%USERPROFILE%/.claude/mcp-servers/obsidian-wrapper.js"
      ]
    },
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest",
        "--user-data-dir=%USERPROFILE%/.claude/chrome-profile",
        "--chromeArg=--disable-blink-features=AutomationControlled",
        "--chromeArg=--disable-features=IsolateOrigins,site-per-process"
      ]
    }
  }
}
