{
  "mcpServers": {
    "university-paper-access": {
      "command": "uv",
      "args": [
        "run",
        "--no-project",
        "--with",
        "mcp>=1.0.0",
        "--with",
        "httpx>=0.27.0",
        "--directory",
        "%USERPROFILE%/.claude/mcp-servers/university-paper-access",
        "python",
        "server.py"
      ]
    },
    "arxiv": {
      "command": "arxiv-mcp-server",
      "args": []
    },
    "semantic-scholar": {
      "command": "semanticscholar-mcp-server",
      "args": []
    },
    "paper-search": {
      "command": "uv",
      "args": [
        "run",
        "--with",
        "paper-search-mcp",
        "python",
        "-c",
        "from paper_search_mcp.server import mcp; mcp.run(transport=\"stdio\")"
      ]
    },
    "paper-mcp": {
      "command": "paper-mcp",
      "args": []
    },
    "scihub": {
      "command": "uv",
      "args": [
        "run",
        "--no-project",
        "--with",
        "mcp>=1.0.0",
        "--with",
        "requests",
        "--with",
        "beautifulsoup4",
        "--with",
        "scihub",
        "--directory",
        "%USERPROFILE%/.claude/mcp-servers/Sci-Hub-MCP-Server",
        "python",
        "sci_hub_server.py"
      ]
    },
    "obsidian": {
      "command": "node",
      "args": [
        "%USERPROFILE%/.claude/mcp-servers/obsidian-wrapper.js"
      ]
    }
  }
}
