{
  "model": "opus",
  "statusLine": {
    "type": "command",
    "command": "powershell -NoProfile -ExecutionPolicy Bypass -File %USERPROFILE%\\.claude\\hooks\\statusline.ps1"
  },
  "hooks": {
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "py -3 %USERPROFILE%\\.claude\\hooks\\precompact-handoff.py"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume|compact",
        "hooks": [
          {
            "type": "command",
            "command": "py -3 %USERPROFILE%\\.claude\\hooks\\session-start-context.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "py -3 %USERPROFILE%\\.claude\\hooks\\stop-persist-todos.py"
          }
        ]
      }
    ]
  },
  "_comment_optional_hooks": "Uncomment the block below to enable the paper-mention-detect hook (off by default).",
  "_optional_hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "py -3 %USERPROFILE%\\.claude\\hooks\\paper-mention-detect.py"
          }
        ]
      }
    ]
  }
}
